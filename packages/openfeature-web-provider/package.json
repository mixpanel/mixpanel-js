{
  "name": "@mixpanel/openfeature-web-provider",
  "version": "0.1.0",
  "description": "OpenFeature Web Provider for Mixpanel feature flags",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "build:browser": "npx rollup -c rollup.config.browser.mjs",
    "build:all": "npm run build && npm run build:browser",
    "test": "mocha --require ts-node/register test/**/*.spec.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@openfeature/web-sdk": "^1.0.0",
    "mixpanel-browser": "^2.68.0"
  },
  "devDependencies": {
    "@openfeature/web-sdk": "^1.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.0",
    "@types/sinon-chai": "^3.2.0",
    "chai": "^4.3.0",
    "mocha": "^10.0.0",
    "sinon": "^17.0.0",
    "sinon-chai": "^3.7.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mixpanel/mixpanel-js.git",
    "directory": "packages/openfeature-web-provider"
  },
  "license": "Apache-2.0",
  "keywords": ["openfeature", "mixpanel", "feature-flags", "provider"]
}
